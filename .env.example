# Server
PORT=3000
FLASK_ENV=development

# Sessão admin — qualquer string aleatória longa (>= 32 chars)
# gere com:  python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-long-random-string

# Senha do admin (bcrypt hash) — gere localmente com:
#   python scripts/hash_password.py "sua-senha-aqui"
# E cole o resultado abaixo (começa com $2b$).
ADMIN_PASSWORD_HASH=

# Onde armazenar o banco SQLite e os .jar enviados pra revisão.
# Em dev local: ./data
# No Railway: aponte para o mount point do volume (ex: /data)
DATA_DIR=./data

# Limite de upload em bytes (default 50MB)
MAX_UPLOAD_BYTES=52428800

# Limites de análise de .jar (anti zip bomb) — defaults costumam bastar
# MAX_ZIP_ENTRIES=10000
# MAX_ZIP_ENTRY_READ_BYTES=8388608
# MAX_ZIP_TOTAL_READ_BYTES=33554432
# MAX_ZIP_COMPRESSION_RATIO=80

# FailMark / PassMark sync (segundos). Default: 7 dias.
# PASSMARK_SYNC_INTERVAL=604800
# Delay entre requests ao cpubenchmark.net (segundos).
# PASSMARK_REQUEST_DELAY=0.35
# Buscar ano via cpu.php (First Seen on Charts). Desligue para sync mais rápido.
# PASSMARK_FETCH_YEARS=1
# PASSMARK_YEAR_WORKERS=8
